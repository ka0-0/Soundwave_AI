APP_NAME=SOUNDWAVE AI API
ENV=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MONGO_URI=mongodb://localhost:27017
MONGO_DB=soundwave_ai

REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace-me-with-strong-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Flask web app (login, OAuth, Spotify search)
FLASK_SECRET_KEY=replace-me-with-strong-secret
FLASK_BASE_URL=http://localhost:5000
FLASK_PORT=5000
FLASK_DEBUG=true

# Spotify API (search + OAuth login)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Google OAuth login
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Genius API (lyrics)
GENIUS_API_KEY=your_genius_api_key
