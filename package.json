{
  "name": "soundwave-ai-root",
  "version": "1.0.0",
  "description": "Production-grade full-stack AI-powered music analytics and recommendation platform with cinematic 3D storytelling.",
  "scripts": {
    "dev": "concurrently -n \"frontend,backend\" -c \"cyan,magenta\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "nodemon --watch backend --ext py --ignore \"backend/.venv/**/*\" --exec \"node scripts/run-backend.js\"",
    "setup:backend": "node scripts/setup-backend.js",
    "postinstall": "npm install --prefix frontend && npm run setup:backend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
